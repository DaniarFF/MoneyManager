@page "/login"
@rendermode InteractiveServer
@layout EmptyLayout
@inject IAuthService AuthService
@inject UserSessionService Session
@inject NavigationManager Nav

<PageTitle>Войти — MoneyManager</PageTitle>

<div class="mobile-shell">
    <div class="login-screen">
        <div class="login-logo">💰</div>
        <h1 class="login-title">MoneyManager</h1>
        <p class="login-subtitle">Управляй бюджетом легко</p>

        @if (_mode == LoginMode.Login)
        {
            <div class="form-group">
                <div class="form-row">
                    <label class="form-label">Слово-пароль</label>
                    <input class="form-input"
                           type="password"
                           placeholder="Введите ваше слово"
                           @bind="_accessKey"
                           @bind:event="oninput"
                           @onkeydown="OnKeyDown"
                           autocomplete="current-password"
                           autofocus/>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(_error))
            {
                <p class="error-msg">@_error</p>
            }

            <button class="login-btn" @onclick="DoLogin" disabled="@_loading">
                @(_loading ? "Входим..." : "Войти")
            </button>

            <button class="login-btn secondary" @onclick="() => _mode = LoginMode.Register">
                Создать аккаунт
            </button>
        }
        else
        {
            <div class="form-group">
                <div class="form-row">
                    <label class="form-label">Ваше имя</label>
                    <input class="form-input"
                           type="text"
                           placeholder="Например: Иван"
                           @bind="_displayName"
                           @bind:event="oninput"
                           autocomplete="name"
                           autofocus/>
                </div>
                <div class="form-row">
                    <label class="form-label">Придумайте слово-пароль</label>
                    <input class="form-input"
                           type="password"
                           placeholder="Уникальное слово (мин. 4 символа)"
                           @bind="_accessKey"
                           @bind:event="oninput"
                           @onkeydown="OnKeyDown"
                           autocomplete="new-password"/>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(_error))
            {
                <p class="error-msg">@_error</p>
            }

            <button class="login-btn" @onclick="DoRegister" disabled="@_loading">
                @(_loading ? "Создаём..." : "Создать аккаунт")
            </button>

            <button class="login-btn secondary" @onclick="() => { _mode = LoginMode.Login; _error = null; }">
                Уже есть аккаунт
            </button>
        }
    </div>
</div>

@code {
    enum LoginMode { Login, Register }

    LoginMode _mode = LoginMode.Login;
    string _accessKey = "";
    string _displayName = "";
    string? _error;
    bool _loading;

    protected override async Task OnInitializedAsync()
    {
        if (Session.IsAuthenticated)
            Nav.NavigateTo("/", replace: true);

        // Если пользователей нет — сразу на регистрацию
        var hasUsers = await AuthService.HasUsersAsync();
        if (!hasUsers)
            _mode = LoginMode.Register;
    }

    async Task DoLogin()
    {
        _error = null;
        _loading = true;
        try
        {
            var result = await AuthService.LoginAsync(_accessKey);
            if (result.Success)
            {
                Session.SetUser(result.UserId!.Value, result.DisplayName!);
                Nav.NavigateTo("/", replace: true);
            }
            else
            {
                _error = result.Error;
            }
        }
        catch (Exception)
        {
            _error = "Ошибка при входе. Попробуйте снова.";
        }
        finally { _loading = false; }
    }

    async Task DoRegister()
    {
        _error = null;
        if (string.IsNullOrWhiteSpace(_displayName))
        {
            _error = "Введите имя.";
            return;
        }

        _loading = true;
        try
        {
            var result = await AuthService.RegisterAsync(_displayName, _accessKey);
            if (result.Success)
            {
                Session.SetUser(result.UserId!.Value, result.DisplayName!);
                Nav.NavigateTo("/setup", replace: true);
            }
            else
            {
                _error = result.Error;
            }
        }
        catch (Exception)
        {
            _error = "Ошибка при создании аккаунта. Попробуйте снова.";
        }
        finally { _loading = false; }
    }

    async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            if (_mode == LoginMode.Login) await DoLogin();
            else await DoRegister();
        }
    }
}
