@using MoneyManager.Application.Commands
@using MoneyManager.Application.DTOs
@using MoneyManager.Application.Services
@inject IExpenseService ExpenseService

<div class="modal-overlay" @onclick="OnClose">
    <div class="modal-sheet" @onclick:stopPropagation>
        <div class="sheet-handle"></div>
        <div class="sheet-header">
            <span class="sheet-title">@GetTitle()</span>
            <button class="sheet-close" @onclick="OnClose">✕</button>
        </div>

        @if (_isIncome)
        {
            <div style="background:#34c759; color:#fff; padding:10px 20px; margin:0 16px 12px; border-radius:12px; text-align:center; font-weight:500">
                💰 Добавление дохода
            </div>
        }

        <!-- Amount -->
        <div class="form-group">
            <div class="form-row">
                <label class="form-label">Сумма</label>
                <div style="display:flex; align-items:baseline; gap:6px">
                    <input class="form-input amount-input"
                           type="number"
                           inputmode="decimal"
                           placeholder="0"
                           value="@(_amount == 0 ? "" : _amount.ToString())"
                           @oninput="OnAmountInput"
                           @onfocus="OnAmountFocus"
                           min="0.01"
                           step="0.01"
                           autofocus/>
                    <span style="font-size:24px; color:@(_isIncome ? "#34c759" : "#c7c7cc"); font-weight:700">₽</span>
                </div>
            </div>
        </div>

        <!-- Category -->
        <p style="font-size:12px; color:#8e8e93; font-weight:600; text-transform:uppercase; letter-spacing:0.5px; padding:4px 20px 0; margin:0">
            Категория
        </p>
        <div class="category-grid">
            @foreach (var cat in GetCategories())
            {
                <div class="cat-chip @(_category == cat.Name ? "selected" : "") @(_isIncome ? "income" : "")"
                     @onclick="() => _category = cat.Name">
                    <span class="cat-icon">@cat.Icon</span>
                    <span class="cat-name">@cat.Name</span>
                </div>
            }
        </div>

        <!-- Note -->
        <div class="form-group">
            <div class="form-row">
                <label class="form-label">Комментарий (необязательно)</label>
                <input class="form-input"
                       type="text"
                       placeholder="@(_isIncome ? "Например: зарплата" : "Например: обед с коллегами")"
                       @bind="_note"
                       maxlength="200"/>
            </div>
            <div class="form-row">
                <label class="form-label">Дата и время</label>
                <input class="form-input"
                       type="datetime-local"
                       @bind="_expenseDate"/>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(_error))
        {
            <p class="error-msg">@_error</p>
        }

        <div style="padding:4px 16px calc(16px + env(safe-area-inset-bottom, 0px)); display:flex; flex-direction:column; gap:10px">
            <button class="login-btn @(_isIncome ? "income-btn" : "")" @onclick="Save" disabled="@(_saving || _amount <= 0)">
                @(_saving ? "Сохраняем..." : GetButtonText())
            </button>

            @if (EditExpense is not null)
            {
                <button class="login-btn" style="background:#ff453a; color:#fff" @onclick="Delete" disabled="@_saving">
                    Удалить @(EditExpense.IsIncome ? "доход" : "расход")
                </button>
            }
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public Guid BudgetPlanId { get; set; }
    [Parameter] public ExpenseDto? EditExpense { get; set; }
    [Parameter] public bool IsIncomeMode { get; set; }
    [Parameter, EditorRequired] public EventCallback OnSaved { get; set; }
    [Parameter, EditorRequired] public EventCallback OnClose { get; set; }

    decimal _amount;
    string _category = "Еда";
    string _note = "";
    DateTime _expenseDate = DateTime.UtcNow;
    string? _error;
    bool _saving;
    bool _isIncome;

    static readonly (string Name, string Icon)[] _expenseCategories =
    [
        ("Еда", "🍔"), ("Кафе", "☕"), ("Транспорт", "🚌"), ("Покупки", "🛍️"),
        ("Развлечения", "🎬"), ("Здоровье", "💊"), ("ЖКХ", "🏠"), ("Связь", "📱"),
        ("Другое", "💸")
    ];

    static readonly (string Name, string Icon)[] _incomeCategories =
    [
        ("Зарплата", "💵"), ("Подработка", "💼"), ("Кэшбэк", "💳"), ("Подарок", "🎁"),
        ("Возврат", "↩️"), ("Другое", "💰")
    ];

    (string Name, string Icon)[] GetCategories() => _isIncome ? _incomeCategories : _expenseCategories;

    string GetTitle()
    {
        if (EditExpense is not null)
            return EditExpense.IsIncome ? "Изменить доход" : "Изменить расход";
        return _isIncome ? "Новый доход" : "Новый расход";
    }

    string GetButtonText()
    {
        if (EditExpense is not null) return "Сохранить";
        return _isIncome ? "Добавить доход" : "Добавить";
    }

    void OnAmountInput(ChangeEventArgs e)
    {
        if (decimal.TryParse(e.Value?.ToString(), out var value))
            _amount = value;
        else
            _amount = 0;
    }

    void OnAmountFocus()
    {
        // Поле автоматически пустое когда _amount = 0
    }

    protected override void OnParametersSet()
    {
        if (EditExpense is not null)
        {
            _amount = EditExpense.Amount;
            _category = EditExpense.Category;
            _note = EditExpense.Note ?? "";
            _expenseDate = EditExpense.ExpenseDate;
            _isIncome = EditExpense.IsIncome;
        }
        else
        {
            _amount = 0;
            _isIncome = IsIncomeMode;
            _category = _isIncome ? "Зарплата" : "Еда";
            _note = "";
            _expenseDate = DateTime.UtcNow;
        }
    }

    async Task Save()
    {
        _error = null;
        if (_amount <= 0) { _error = "Введите сумму."; return; }
        if (string.IsNullOrWhiteSpace(_category)) { _error = "Выберите категорию."; return; }

        _saving = true;
        try
        {
            if (EditExpense is null)
            {
                await ExpenseService.AddExpenseAsync(new AddExpenseCommand(
                    BudgetPlanId, _amount, _category, _note.Trim() == "" ? null : _note.Trim(), _expenseDate, _isIncome));
            }
            else
            {
                await ExpenseService.UpdateExpenseAsync(new UpdateExpenseCommand(
                    EditExpense.Id, _amount, _category, _note.Trim() == "" ? null : _note.Trim(), _expenseDate, _isIncome));
            }
            await OnSaved.InvokeAsync();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _saving = false; }
    }

    async Task Delete()
    {
        if (EditExpense is null) return;
        _saving = true;
        try
        {
            await ExpenseService.DeleteExpenseAsync(EditExpense.Id);
            await OnSaved.InvokeAsync();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _saving = false; }
    }
}
